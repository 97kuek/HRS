# このファイルをコピーして .env を作成する（.env はコミットしない）。
#   PowerShell: Copy-Item .env.example .env
# public リポジトリのため、実際の接続URL・秘密情報は .env にだけ書き、コミット/Issue/PR に貼らない。

# Prisma が接続する Postgres URL（必須）。
# - Neon（既定・推奨）: ダッシュボードの "Direct connection" の URL を貼る。
#     （direct を使えば migration もアプリ実行もこの1本でよく、DIRECT_URL は空のまま）
# - Docker（任意の代替）: compose.yaml の値に合わせる。
#     例: postgresql://hrs_user:hrs_password@localhost:5432/hrs_dev
DATABASE_URL="postgresql://hrs_user:hrs_password@localhost:5432/hrs_dev"

# マイグレーション用の直接接続URL（任意）。
# Neon の "Pooled connection" を DATABASE_URL に使う場合のみ、ここに "Direct connection" を入れる。
# 上記の推奨（DATABASE_URL に direct を使う）構成では空のままでよい。
DIRECT_URL=""

# 公開されてよい値のみ（NEXT_PUBLIC_ はブラウザに露出する）。
NEXT_PUBLIC_APP_NAME="HRS"
APP_BASE_URL="http://localhost:3000"

# メール送信（Resend）。
# resend.com でアカウント作成後 API キーを発行して設定する。
# RESEND_FROM_EMAIL には Resend で認証したドメインのアドレスを設定する。
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@example.com"

# Vercel Cron Job の認証トークン（任意の長い乱数文字列）。
# openssl rand -base64 32 などで生成して Vercel 環境変数にも同じ値を設定する。
CRON_SECRET=""
