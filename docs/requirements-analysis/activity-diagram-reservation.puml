@startuml
title UC「部屋を予約する」アクティビティ図

start

repeat
  :利用者が宿泊日・泊数・人数・部屋タイプを入力する;
  :HRSが入力条件の妥当性を確認する;
  if (入力条件は妥当か) then (いいえ)
    :HRSが不正な項目と修正方法を表示する;
  endif
repeat while (入力条件が不正か) is (はい)
->いいえ;

repeat
  :HRSが条件に合う空室を検索する;
  if (条件に合う空室があるか) then (いいえ)
    :HRSが空室がないことを表示し、条件変更を促す;
    if (利用者が条件を変更するか) then (はい)
      :利用者が検索条件を変更する;
    else (いいえ)
      :HRSが予約情報を作成せず操作を終了する;
      stop
    endif
  endif
repeat while (条件に合う空室がないか) is (はい)
->いいえ;

repeat
  :HRSが部屋候補と宿泊料金を表示する;
  :利用者が予約する部屋を選択する;
  :HRSが選択された部屋の最新の空室状況を確認する;
  if (選択した部屋を予約できるか) then (いいえ)
    :HRSが予約できない理由を表示する;
    :HRSが最新の空室候補を表示する;
  endif
repeat while (選択した部屋を予約できないか) is (はい)
->いいえ;

:HRSが利用者情報の入力画面を表示する;

repeat
  :利用者が氏名・連絡先・宿泊者情報を入力する;
  :HRSが利用者情報の妥当性を確認する;
  if (利用者情報は妥当か) then (いいえ)
    :HRSが不正な項目と修正方法を表示する;
  endif
repeat while (利用者情報が不正か) is (はい)
->いいえ;

:HRSが予約内容の確認画面を表示する;

if (利用者が予約内容を確定するか) then (確定)
  :利用者が予約確定を指示する;
else (修正または中止)
  if (利用者が修正するか) then (修正)
    :HRSが修正対象の入力画面を表示する;
    note right
      修正対象に応じて
      部屋選択または利用者情報入力に戻る
    end note
    stop
  else (中止)
    :HRSが予約情報を作成せず操作を終了する;
    stop
  endif
endif

:HRSが予約情報を登録する;

if (予約登録に成功したか) then (はい)
  :HRSが予約番号を発行する;
  :HRSが予約番号と予約内容を表示する;
else (いいえ)
  :HRSが予約を完了できないことを表示する;
endif

stop

@enduml
